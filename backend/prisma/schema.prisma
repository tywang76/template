generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Item {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String
  value String

  @@map("items")
}

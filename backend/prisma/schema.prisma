generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Node {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  state     NodeState
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  from      Json[]    @default([])
  to        Json[]    @default([])

  @@map("nodes")
}

model Edge {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  from      String
  to        String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("edges")
}

enum NodeState {
  Question
  Rule
  Action
}
